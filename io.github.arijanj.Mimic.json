{
    "id": "io.github.arijanj.Mimic",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "mimic",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--filesystem=host-os:ro",
        "--filesystem=~/.local/share/applications:ro",
        "--filesystem=~/.local/share/icons:ro",
        "--filesystem=~/.local/share/flatpak/exports/share/applications:ro",
        "--filesystem=/var/lib/flatpak/app:ro",
        "--filesystem=/var/lib/flatpak/exports/share/applications:ro",
        "--filesystem=/var/lib/flatpak/exports/share/icons:ro",
        "--filesystem=~/.local/share/flatpak/exports/share/icons:ro",
        "--filesystem=/var/lib/snapd:ro",
        "--filesystem=/snap:ro",
        "--filesystem=/run/current-system/sw/share/applications:ro",
        "--filesystem=xdg-config:create"
    ],
    "modules": [
        {
            "name": "mimic",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/ArijanJ/mimic",
                    "tag": "v1.1.2",
                    "commit": "34fd59729b4c08d11056aa531f64dc5e78c1d249"
                }
            ]
        }
    ]
}
